rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSeller() {
      return isSignedIn() && (
        request.auth.token.role == 'seller' ||
        request.auth.token.role == 'both' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'both'
      );
    }

    function hasBookAccess(bookId) {
      return isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/books/$(bookId)).data.sellerId == request.auth.uid ||
        exists(/databases/$(database)/documents/library/$(request.auth.uid + '_' + bookId)) ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus == 'active' &&
          get(/databases/$(database)/documents/books/$(bookId)).data.inSubscription == true
        )
      );
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Books
    match /books/{bookId} {
      allow read: if resource.data.status == 'live' || isAdmin() ||
        (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if isSeller();
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();

      // Chapters
      match /chapters/{chapterId} {
        allow read: if resource.data.isPreview == true || hasBookAccess(bookId);
        allow write: if isAdmin() ||
          (isSignedIn() && get(/databases/$(database)/documents/books/$(bookId)).data.sellerId == request.auth.uid);
      }
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid ||
         isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // Library
    match /library/{itemId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Wishlist
    match /wishlist/{itemId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Reading progress
    match /readingProgress/{progressId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.reviewerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Subscriptions
    match /subscriptions/{subId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Payouts
    match /payouts/{payoutId} {
      allow read: if isSignedIn() &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.isActive == true);
      allow write: if isAdmin();
    }

    // Promo codes
    match /promoCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() ||
        (isSeller() && resource.data.sellerId == request.auth.uid);
    }

    // Platform settings
    match /platformSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Borrow records
    match /borrowRecords/{recordId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ID Verification requests
    match /verificationRequests/{reqId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Sellers (public profile data)
    match /sellers/{sellerId} {
      allow read: if true;
      allow create: if isOwner(sellerId) || isAdmin();
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
