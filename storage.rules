rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    // Book covers — sellerId in path so ownership can be enforced
    match /covers/{sellerId}/{bookId}/{filename} {
      allow read: if true;
      allow create, update: if isOwner(sellerId) &&
        request.resource.size < 5 * 1024 * 1024 &&
        isImage();
      allow delete: if isOwner(sellerId) || isAdmin();
    }

    // Raw manuscript files — stored alongside parsed Firestore chapters for copyright records
    match /manuscripts/{sellerId}/{bookId}/{filename} {
      allow read: if isOwner(sellerId) || isAdmin();
      allow create, update: if isOwner(sellerId) &&
        request.resource.size < 50 * 1024 * 1024 &&
        (request.resource.contentType == 'text/plain' ||
         request.resource.contentType == 'text/markdown' ||
         request.resource.contentType.matches('text/.*'));
      allow delete: if isOwner(sellerId) || isAdmin();
    }

    // User avatars — public read, owner write/delete
    match /avatars/{userId}/{filename} {
      allow read: if true;
      allow create, update: if isOwner(userId) &&
        request.resource.size < 2 * 1024 * 1024 &&
        isImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ID verification documents — owner uploads (image or PDF), only admin reads
    match /verification/{userId}/{filename} {
      allow read: if isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.size < 10 * 1024 * 1024 &&
        isImageOrPdf();
      allow delete: if isAdmin();
    }

    // Tax forms — owner uploads (image or PDF), only admin reads
    match /tax/{userId}/{filename} {
      allow read: if isAdmin();
      allow create, update: if isOwner(userId) &&
        request.resource.size < 10 * 1024 * 1024 &&
        isImageOrPdf();
      allow delete: if isAdmin();
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
